<UserControl x:Class="StarLibEditor.Controls.ColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="260" Height="280">

    <Border Background="#252525" CornerRadius="8" Padding="12" BorderBrush="#444" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Color Picker" Foreground="#E0E0E0" FontWeight="SemiBold"
                       FontSize="12" Margin="0,0,0,8"/>

            <!-- SV Square + Hue Bar -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                </Grid.ColumnDefinitions>

                <!-- Saturation/Value square -->
                <Border Grid.Column="0" x:Name="SVSquare" Background="Red" CornerRadius="4"
                        Cursor="Cross" MouseLeftButtonDown="SV_MouseDown" MouseMove="SV_MouseMove"
                        MouseLeftButtonUp="SV_MouseUp" ClipToBounds="True">
                    <Grid>
                        <Border CornerRadius="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border CornerRadius="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="Black" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Cursor indicator -->
                        <Ellipse x:Name="SVCursor" Width="12" Height="12" Stroke="White" StrokeThickness="2"
                                 Fill="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top"
                                 IsHitTestVisible="False" Margin="-6,-6,0,0"/>
                    </Grid>
                </Border>

                <!-- Hue bar -->
                <Border Grid.Column="1" Margin="6,0,0,0" CornerRadius="4" ClipToBounds="True"
                        Cursor="Hand" MouseLeftButtonDown="Hue_MouseDown" MouseMove="Hue_MouseMove"
                        MouseLeftButtonUp="Hue_MouseUp" x:Name="HueBar">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF0000" Offset="0.000"/>
                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                            <GradientStop Color="#00FF00" Offset="0.333"/>
                            <GradientStop Color="#00FFFF" Offset="0.500"/>
                            <GradientStop Color="#0000FF" Offset="0.667"/>
                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                            <GradientStop Color="#FF0000" Offset="1.000"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Canvas>
                        <Border x:Name="HueCursor" Width="24" Height="4" Background="White"
                                BorderBrush="#333" BorderThickness="1" Canvas.Left="0" Canvas.Top="0"
                                IsHitTestVisible="False"/>
                    </Canvas>
                </Border>
            </Grid>

            <!-- Preview + Hex -->
            <Grid Grid.Row="2" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" x:Name="PreviewSwatch" Width="32" Height="32"
                        CornerRadius="6" Background="Red" BorderBrush="#555" BorderThickness="1"/>

                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Hex" Foreground="#888" FontSize="9" Margin="0,0,0,2"/>
                    <TextBox x:Name="HexInput" Text="#FF0000" FontSize="12" FontFamily="Consolas"
                             Background="#1E1E1E" Foreground="White" BorderBrush="#444" BorderThickness="1"
                             Padding="4,2" LostFocus="HexInput_LostFocus"/>
                </StackPanel>
            </Grid>

            <!-- RGB Inputs -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <TextBlock Text="R" Foreground="#FF6666" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBox x:Name="RInput" Text="255" FontSize="11" Background="#1E1E1E" Foreground="White"
                             BorderBrush="#444" BorderThickness="1" Padding="4,2" TextAlignment="Center"
                             LostFocus="RGB_LostFocus"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="2,0,2,0">
                    <TextBlock Text="G" Foreground="#66FF66" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBox x:Name="GInput" Text="0" FontSize="11" Background="#1E1E1E" Foreground="White"
                             BorderBrush="#444" BorderThickness="1" Padding="4,2" TextAlignment="Center"
                             LostFocus="RGB_LostFocus"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="4,0,0,0">
                    <TextBlock Text="B" Foreground="#6666FF" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBox x:Name="BInput" Text="0" FontSize="11" Background="#1E1E1E" Foreground="White"
                             BorderBrush="#444" BorderThickness="1" Padding="4,2" TextAlignment="Center"
                             LostFocus="RGB_LostFocus"/>
                </StackPanel>
            </Grid>

            <!-- Confirm / Cancel -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="Cancel" Padding="12,4" Margin="0,0,6,0"
                        Background="#333" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="Cancel_Click"/>
                <Button x:Name="ConfirmBtn" Content="Confirm" Padding="12,4"
                        Background="#0078D4" Foreground="White" BorderThickness="0"
                        FontWeight="Bold" Cursor="Hand" Click="Confirm_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
