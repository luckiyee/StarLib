<UserControl x:Class="StarLibEditor.Controls.DragDropCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True">

    <Canvas x:Name="InnerCanvas" Background="Transparent"
            AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver"
            DragLeave="OnDragLeave">
        <!-- Insertion indicator line -->
        <Border x:Name="InsertionLine" Height="2" Width="200"
                Background="#00AAFF" Visibility="Collapsed"
                IsHitTestVisible="False" Canvas.Left="0" Canvas.Top="0"/>
    </Canvas>
</UserControl>
