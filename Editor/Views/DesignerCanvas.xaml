<UserControl x:Class="StarLibEditor.Views.DesignerCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource CanvasBackground}"
             AllowDrop="True"
             Drop="Canvas_Drop"
             DragOver="Canvas_DragOver">

    <Grid>
        <!-- Canvas background with subtle grid -->
        <Border x:Name="CanvasHost" ClipToBounds="True">
            <Grid>
                <!-- Grid pattern background -->
                <Canvas x:Name="GridCanvas" IsHitTestVisible="False"/>

                <!-- Zoom container -->
                <Border x:Name="ZoomBorder" HorizontalAlignment="Center" VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>

                    <!-- StarLib window mockup -->
                    <Border x:Name="MockupFrame" Width="600" Height="400"
                            Background="#181818" CornerRadius="8"
                            BorderBrush="#333" BorderThickness="1"
                            >
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- TopBar -->
                            <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8,8,0,0">
                                <Grid>
                                    <TextBlock x:Name="MockupTitle" Text="My Script"
                                               Foreground="White" FontWeight="Bold" FontSize="14"
                                               VerticalAlignment="Center" Margin="15,0"/>
                                    <TextBlock Text="-" Foreground="#AAA" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Sidebar -->
                                <Border Grid.Column="0" Background="#1E1E1E">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="SidebarPanel" Margin="10,10"/>
                                    </ScrollViewer>
                                </Border>

                                <!-- Content area -->
                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="ContentPanel" Margin="15,15">
                                        <!-- Widgets rendered here -->
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- Zoom indicator -->
        <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="{StaticResource TextMuted}"
                   FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,10,10"/>

        <!-- Drop indicator -->
        <Border x:Name="DropIndicator" Height="2" Background="{StaticResource AccentBrush}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                IsHitTestVisible="False"/>
    </Grid>
</UserControl>
