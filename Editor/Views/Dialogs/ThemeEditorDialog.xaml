<Window x:Class="StarLibEditor.Views.Dialogs.ThemeEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Theme Editor" Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Theme Properties -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Background="#252525" Padding="8,6">
                <StackPanel>
                    <TextBlock Text="THEME PROPERTIES" Foreground="#888" FontSize="11" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Preset: " Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PresetCombo" Width="160" SelectionChanged="PresetChanged">
                            <ComboBoxItem Content="Dark (Default)" IsSelected="True"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="Midnight Blue"/>
                            <ComboBoxItem Content="Blood Red"/>
                            <ComboBoxItem Content="Neon Green"/>
                            <ComboBoxItem Content="Rose Gold"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ThemePropsPanel" Margin="8"/>
            </ScrollViewer>
        </DockPanel>

        <!-- Right: Live Preview -->
        <DockPanel Grid.Column="1" Background="#111">
            <Border DockPanel.Dock="Top" Background="#252525" Padding="8,6">
                <TextBlock Text="LIVE PREVIEW" Foreground="#888" FontSize="11" FontWeight="Bold"/>
            </Border>
            <Border Margin="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border x:Name="PreviewFrame" Width="400" Height="280"
                        CornerRadius="8" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.4"/>
                    </Border.Effect>
                    <Grid x:Name="PreviewContent"/>
                </Border>
            </Border>
        </DockPanel>
    </Grid>
</Window>
