<Window x:Class="StarLibEditor.Views.Dialogs.SimulateKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simulate Key Press" Width="300" Height="180"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E">
    <StackPanel Margin="16">
        <TextBlock Text="Select a key to simulate:" Foreground="#E0E0E0" FontSize="13" Margin="0,0,0,8"/>
        <ComboBox x:Name="KeyCombo" IsEditable="True" FontSize="12" Margin="0,0,0,16">
            <ComboBoxItem Content="F" IsSelected="True"/>
            <ComboBoxItem Content="RightShift"/>
            <ComboBoxItem Content="LeftShift"/>
            <ComboBoxItem Content="LeftControl"/>
            <ComboBoxItem Content="RightControl"/>
            <ComboBoxItem Content="Space"/>
            <ComboBoxItem Content="Return"/>
            <ComboBoxItem Content="Escape"/>
            <ComboBoxItem Content="E"/>
            <ComboBoxItem Content="Q"/>
            <ComboBoxItem Content="R"/>
            <ComboBoxItem Content="T"/>
            <ComboBoxItem Content="X"/>
            <ComboBoxItem Content="Z"/>
        </ComboBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Padding="16,4" Margin="0,0,8,0"
                    Background="#333" Foreground="White" BorderThickness="0"/>
            <Button Content="Fire" Click="Fire_Click" Padding="16,4"
                    Background="#0078D4" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </StackPanel>
</Window>
