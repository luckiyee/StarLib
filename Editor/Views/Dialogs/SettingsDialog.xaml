<Window x:Class="StarLibEditor.Views.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="520" Height="450"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#E0E0E0"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- General Settings -->
                <TextBlock Text="GENERAL" FontWeight="SemiBold" FontSize="12"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>

                <DockPanel Margin="0,4">
                    <TextBlock Text="Default project location" Width="180"
                               Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding DefaultProjectPath}" Background="#2D2D2D"
                             Foreground="#E0E0E0" BorderBrush="#333" BorderThickness="1"
                             Padding="4,3" FontSize="12"/>
                </DockPanel>

                <DockPanel Margin="0,4">
                    <TextBlock Text="StarLib path" Width="180"
                               Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding StarLibPath}" Background="#2D2D2D"
                             Foreground="#E0E0E0" BorderBrush="#333" BorderThickness="1"
                             Padding="4,3" FontSize="12"/>
                </DockPanel>

                <DockPanel Margin="0,4">
                    <TextBlock Text="Use Upgraded StarLib" Width="180"
                               Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    <CheckBox IsChecked="{Binding UseUpgradedStarLib}" VerticalAlignment="Center"/>
                </DockPanel>

                <Separator Background="#333" Margin="0,12"/>

                <!-- Editor Settings -->
                <TextBlock Text="EDITOR" FontWeight="SemiBold" FontSize="12"
                           Foreground="{StaticResource AccentBrush}" Margin="0,8,0,8"/>

                <DockPanel Margin="0,4">
                    <TextBlock Text="Font size" Width="180"
                               Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding EditorFontSize}" Background="#2D2D2D"
                             Foreground="#E0E0E0" BorderBrush="#333" BorderThickness="1"
                             Padding="4,3" FontSize="12" Width="60" HorizontalAlignment="Left"/>
                </DockPanel>

                <DockPanel Margin="0,4">
                    <TextBlock Text="Show line numbers" Width="180"
                               Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    <CheckBox IsChecked="{Binding ShowLineNumbers}" VerticalAlignment="Center"/>
                </DockPanel>

                <DockPanel Margin="0,4">
                    <TextBlock Text="Word wrap" Width="180"
                               Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    <CheckBox IsChecked="{Binding WordWrap}" VerticalAlignment="Center"/>
                </DockPanel>

                <Separator Background="#333" Margin="0,12"/>

                <!-- Auto-save Settings -->
                <TextBlock Text="AUTO-SAVE" FontWeight="SemiBold" FontSize="12"
                           Foreground="{StaticResource AccentBrush}" Margin="0,8,0,8"/>

                <DockPanel Margin="0,4">
                    <TextBlock Text="Enable auto-save" Width="180"
                               Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    <CheckBox IsChecked="{Binding AutoSaveEnabled}" VerticalAlignment="Center"/>
                </DockPanel>

                <DockPanel Margin="0,4">
                    <TextBlock Text="Interval (seconds)" Width="180"
                               Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding AutoSaveInterval}" Background="#2D2D2D"
                             Foreground="#E0E0E0" BorderBrush="#333" BorderThickness="1"
                             Padding="4,3" FontSize="12" Width="60" HorizontalAlignment="Left"/>
                </DockPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource ToolbarButton}"
                    Width="80" Padding="8,6" Margin="0,0,8,0"
                    Click="OnCancelClick"/>
            <Button Content="OK" Width="80" Padding="8,6"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontSize="12"
                    Click="OnOkClick"/>
        </StackPanel>
    </Grid>
</Window>
