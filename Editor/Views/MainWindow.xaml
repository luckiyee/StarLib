<Window x:Class="StarLibEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StarLibEditor.ViewModels"
        xmlns:views="clr-namespace:StarLibEditor.Views"
        Title="{Binding TitleText}" Height="800" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PanelBackground}"
        Icon="/Assets/Icons/starlib.ico">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveProjectAsCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding Designer.RemoveNodeCommand}"
                    CommandParameter="{Binding Designer.SelectedNode}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource ToolbarBackground}"
              Foreground="{StaticResource TextForeground}">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open Project..." Command="{Binding OpenProjectCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveProjectAsCommand}" InputGestureText="Ctrl+Shift+S"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Duplicate" Command="{Binding Designer.DuplicateNodeCommand}"
                          CommandParameter="{Binding Designer.SelectedNode}"/>
                <MenuItem Header="Delete" Command="{Binding Designer.RemoveNodeCommand}"
                          CommandParameter="{Binding Designer.SelectedNode}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Palette" Command="{Binding TogglePaletteCommand}"/>
                <MenuItem Header="Toggle _Hierarchy" Command="{Binding ToggleHierarchyCommand}"/>
                <MenuItem Header="Toggle _Inspector" Command="{Binding ToggleInspectorCommand}"/>
                <MenuItem Header="Toggle _Code Panel" Command="{Binding ToggleCodePanelCommand}"/>
                <Separator/>
                <MenuItem Header="Zoom _In" Command="{Binding Designer.ZoomInCommand}"/>
                <MenuItem Header="Zoom _Out" Command="{Binding Designer.ZoomOutCommand}"/>
                <MenuItem Header="_Reset Zoom" Command="{Binding Designer.ZoomResetCommand}"/>
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="Open _Emulator" Command="{Binding OpenEmulatorCommand}"/>
            </MenuItem>
            <MenuItem Header="E_xport">
                <MenuItem Header="Export _Lua..." Command="{Binding ExportLuaCommand}"/>
                <MenuItem Header="_Copy Lua to Clipboard" Command="{Binding CopyLuaToClipboardCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" Background="{StaticResource ToolbarBackground}">
            <ToolBar Background="{StaticResource ToolbarBackground}" Band="0" BandIndex="0">
                <Button Content="New" Command="{Binding NewProjectCommand}" Style="{StaticResource ToolbarButton}"/>
                <Button Content="Open" Command="{Binding OpenProjectCommand}" Style="{StaticResource ToolbarButton}"/>
                <Button Content="Save" Command="{Binding SaveProjectCommand}" Style="{StaticResource ToolbarButton}"/>
                <Separator/>
                <Button Content="Undo" Command="{Binding UndoCommand}" Style="{StaticResource ToolbarButton}"/>
                <Button Content="Redo" Command="{Binding RedoCommand}" Style="{StaticResource ToolbarButton}"/>
                <Separator/>
                <Button Content="▶ Run Emulator" Command="{Binding OpenEmulatorCommand}" Style="{StaticResource ToolbarButton}"
                        Foreground="#FFFFFF" FontWeight="Bold"/>
                <Separator/>
                <Button Content="Export Lua" Command="{Binding ExportLuaCommand}" Style="{StaticResource ToolbarButton}"/>
                <Button Content="Copy Lua" Command="{Binding CopyLuaToClipboardCommand}" Style="{StaticResource ToolbarButton}"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Main Content Area -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200" MinHeight="100"/>
            </Grid.RowDefinitions>

            <!-- Top Section: Left | Canvas | Right -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Palette + Hierarchy -->
                <Grid Grid.Column="0" Visibility="{Binding IsPaletteVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <views:PalettePanel Grid.Row="0" DataContext="{Binding Palette}"/>
                    <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                    <views:HierarchyPanel Grid.Row="2" DataContext="{Binding Hierarchy}"
                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </Grid>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                <!-- Center: Designer Canvas -->
                <views:DesignerCanvas Grid.Column="2" DataContext="{Binding Designer}"
                                      Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                <!-- Right: Inspector -->
                <views:InspectorPanel Grid.Column="4" DataContext="{Binding Inspector}"
                                       Visibility="{Binding DataContext.IsInspectorVisible,
                                       RelativeSource={RelativeSource AncestorType=Window},
                                       Converter={StaticResource BoolToVisibility}}"
                                       Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>

            <!-- Horizontal Splitter -->
            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Visibility="{Binding IsCodePanelVisible, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Bottom: Code Panel -->
            <views:CodePanel Grid.Row="2" DataContext="{Binding CodePanel}"
                             Visibility="{Binding DataContext.IsCodePanelVisible,
                             RelativeSource={RelativeSource AncestorType=Window},
                             Converter={StaticResource BoolToVisibility}}"
                             Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Grid>
    </DockPanel>
</Window>
