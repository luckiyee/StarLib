<UserControl x:Class="StarLibEditor.Views.CodePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             Background="{StaticResource PanelBackground}">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource ToolbarBackground}" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="LUA OUTPUT" Style="{StaticResource PanelHeader}" VerticalAlignment="Center"/>
                <Button Content="Copy" Command="{Binding CopyToClipboardCommand}" Style="{StaticResource ToolbarButton}" Margin="8,0"/>
                <Button Content="Export..." Command="{Binding ExportToFileCommand}" Style="{StaticResource ToolbarButton}"/>
                <Separator Margin="8,4"/>
                <CheckBox Content="Edit Mode" IsChecked="{Binding IsEditMode}" Foreground="{StaticResource TextForeground}"
                          VerticalAlignment="Center" Margin="4,0" FontSize="11"/>
                <CheckBox Content="Minify" IsChecked="{Binding IsMinified}" Foreground="{StaticResource TextForeground}"
                          VerticalAlignment="Center" Margin="8,0" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Diagnostics bar -->
        <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Diagnostics}" Margin="4,2">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock FontSize="11" Margin="4,1">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                        <Setter Property="Foreground" Value="#FFCC00"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="Error">
                                        <Setter Property="Foreground" Value="#FF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding Severity, Mode=OneWay}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding Message, Mode=OneWay}"/>
                    </TextBlock>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Code editor -->
        <avalonedit:TextEditor x:Name="CodeEditor"
                               FontFamily="Consolas" FontSize="12"
                               Background="#1A1A1A" Foreground="#D4D4D4"
                               ShowLineNumbers="True"
                               IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"/>
    </DockPanel>
</UserControl>
