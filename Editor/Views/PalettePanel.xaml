<UserControl x:Class="StarLibEditor.Views.PalettePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StarLibEditor.ViewModels"
             Background="{StaticResource PanelBackground}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="PALETTE" Style="{StaticResource PanelHeader}"/>

        <!-- Palette / Assets / Templates tab strip -->
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1" Margin="4,0">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Widgets" IsChecked="True" GroupName="PaletteTabs"
                             Foreground="{StaticResource TextForeground}" Margin="4,2" FontSize="11"/>
                <RadioButton Content="Assets" GroupName="PaletteTabs"
                             Foreground="{StaticResource TextForeground}" Margin="4,2" FontSize="11"/>
                <RadioButton Content="Templates" GroupName="PaletteTabs"
                             Foreground="{StaticResource TextForeground}" Margin="4,2" FontSize="11"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}" Margin="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Header="{Binding Name}" IsExpanded="True" Foreground="{StaticResource TextMuted}"
                                  FontSize="10" FontWeight="Bold" Margin="0,4">
                            <ItemsControl ItemsSource="{Binding Items}" Margin="4,2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource InputBackground}" CornerRadius="4"
                                                Margin="0,1" Padding="8,5" Cursor="Hand"
                                                MouseLeftButtonDown="PaletteItem_MouseLeftButtonDown"
                                                ToolTip="{Binding Tooltip}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3A3A3A"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextForeground}"
                                                       FontSize="12" FontWeight="Normal"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
