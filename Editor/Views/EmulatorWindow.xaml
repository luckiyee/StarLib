<Window x:Class="StarLibEditor.Views.EmulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StarLib Emulator" Width="1360" Height="860"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#252525" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="▶ Run" Click="RunButton_Click" Margin="2" Padding="12,4"
                        Background="#0078D4" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                <Button Content="⏹ Stop" Click="StopButton_Click" Margin="2" Padding="12,4"
                        Background="#444" Foreground="White" BorderThickness="0"/>
                <Button Content="⟳ Reload" Click="ReloadButton_Click" Margin="2" Padding="12,4"
                        Background="#444" Foreground="White" BorderThickness="0"/>
                <Separator Margin="8,2"/>
                <Button Content="Simulate Key..." Click="SimulateKeyButton_Click" Margin="2" Padding="12,4"
                        Background="#444" Foreground="White" BorderThickness="0"/>
                <Separator Margin="8,2"/>
                <TextBlock Text="Player:" Foreground="#888" VerticalAlignment="Center" Margin="8,0,4,0"/>
                <TextBox x:Name="PlayerNameBox" Text="TestPlayer" Width="100"
                         Background="#333" Foreground="White" BorderThickness="0" Padding="4,2"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Emulator Screen -->
        <Border Grid.Row="1" Background="#0D0D0D" Margin="8">
            <Viewbox Stretch="Uniform">
                <Border Width="1280" Height="720" Background="#111" ClipToBounds="True">
                    <Canvas x:Name="EmulatorCanvas" Width="1280" Height="720"
                            Background="#111111" ClipToBounds="True"/>
                </Border>
            </Viewbox>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                      Background="#404040" ShowsPreview="True"/>

        <!-- Console Output -->
        <Border Grid.Row="3" Background="#1E1E1E" Margin="8,0,8,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#252525" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="CONSOLE" Foreground="#888" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Content="Clear" Click="ClearConsole_Click" Margin="12,0,0,0"
                                Background="Transparent" Foreground="#888" BorderThickness="0"
                                FontSize="11" Cursor="Hand"/>
                    </StackPanel>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="ConsoleScroll">
                    <ItemsControl x:Name="ConsoleList" Margin="8,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Consolas" FontSize="12" Margin="0,1" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#D4D4D4"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Foreground" Value="#FFCC00"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Foreground" Value="#FF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss}] ', Mode=OneWay}" Foreground="#666"/>
                                    <Run Text="{Binding Message, Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="#252525" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#888" Margin="0,0,6,0"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Stopped" Foreground="#888" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Text="  |  1280×720" Foreground="#555" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
