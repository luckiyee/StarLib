<UserControl x:Class="StarLibEditor.Views.HierarchyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StarLibEditor.ViewModels"
             Background="{StaticResource PanelBackground}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="HIERARCHY" Style="{StaticResource PanelHeader}"/>

        <!-- Search Filter -->
        <Border DockPanel.Dock="Top" Background="{StaticResource InputBackground}" CornerRadius="4" Margin="6,0,6,4" Padding="4,2">
            <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextForeground}"
                     FontSize="11" Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Tag" Value="Search nodes..."/>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Border>

        <!-- Add Tab button -->
        <Button DockPanel.Dock="Top" Content="+ Add Tab" Command="{Binding AddTabCommand}"
                Style="{StaticResource ToolbarButton}" HorizontalAlignment="Left" Margin="6,0" FontSize="11"/>

        <!-- Tree View -->
        <TreeView Background="Transparent" BorderThickness="0" Margin="4"
                  x:Name="HierarchyTree">
            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="IsExpanded" Value="True"/>
                    <Setter Property="Padding" Value="2"/>
                </Style>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</UserControl>
